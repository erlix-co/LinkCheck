backend/*.pyo
backend/*.pyd

# Env files / secrets
.env
.env.*
backend/.env
backend/.env.*
frontend/.env
frontend/.env.*

# Keys / local secrets (if ever added)
*.pem
*.key

# Coverage / test artifacts
coverage/
.coverage
.pytest_cache/
